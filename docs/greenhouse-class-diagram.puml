@startuml greenhouse_class_diagram
hide empty members
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
left to right direction

title Greenhouse Project - Class Diagram (Backend + Controller)

package "backend.config" {
  class "Settings" as B_Settings {
    +database_url: str
    +redis_url: str
    +redis_sensor_cache_ttl_seconds: int
    +api_title: str
    +api_version: str
    +debug: bool
  }
}

package "backend.models (SQLAlchemy)" {
  class "Device" as BM_Device {
    +id: UUID
    +name: str
    +description: str?
    +device_type: str
    +location: str
    +firmware: str?
    +unit: str?
    +created_at: datetime
    +updated_at: datetime
  }

  class "SensorReading" as BM_SensorReading {
    +time: datetime
    +sensor_id: UUID
    +value: float
  }

  class "LightSchedule" as BM_LightSchedule {
    +id: UUID
    +name: str
    +description: str?
    +light_on_start: time?
    +light_on_end: time?
    +brightness_level: int
  }

  class "LightScheduleDate" as BM_LightScheduleDate {
    +schedule_id: UUID
    +start_date: date
    +enabled: bool
  }

  class "WateringSchedule" as BM_WateringSchedule {
    +id: UUID
    +name: str
    +duration_seconds: int
    +moisture_threshold_max: float?
    +moisture_threshold_auto: float?
    +moisture_auto_enabled: bool
    +frequency_hours: int
  }

  class "WateringScheduleDate" as BM_WateringScheduleDate {
    +schedule_id: UUID
    +start_date: date
    +enabled: bool
  }

  class "Log" as BM_Log {
    +id: UUID
    +device_id: UUID
    +log_level: str
    +message: str
    +created_at: datetime
  }

  class "Alert" as BM_Alert {
    +id: UUID
    +device_id: UUID
    +alert_type: str
    +severity: str
    +message: str
    +resolved: bool
    +created_at: datetime
    +resolved_at: datetime?
  }
}

BM_SensorReading }o-- BM_Device : sensor_id
BM_Log }o-- BM_Device : device_id
BM_Alert }o-- BM_Device : device_id
BM_LightScheduleDate }o-- BM_LightSchedule : schedule_id
BM_WateringScheduleDate }o-- BM_WateringSchedule : schedule_id

