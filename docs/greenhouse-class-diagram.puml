package "controller (C++)" {
  enum "DeviceType" as C_DeviceType {
    SENSOR
    MOISTURE
    LIGHT
  }

  class "device_type namespace" as C_DeviceTypeNS <<utility>> {
    +parseRemoteDeviceType(deviceType)
    +deviceTypeToString(type)
  }

  class "SensorReading" as C_SensorReading {
    +deviceId: string
    +timestamp: time_point
    +value: double
    +unit: string
  }

  abstract class "Device" as C_Device {
    +id(): string
    +name(): string
    +location(): string
    +firmware(): string
    +enabled(): bool
    +setEnabled(enabled)
    +type(): DeviceType
    +toString(): string
    +fromJson(remoteDevice): unique_ptr<Device>
  }

  abstract class "SensorDevice" as C_SensorDevice {
    +validateValue(value): bool
    +unit(): string
    +recordReading(value, timestamp): bool
    +latestReading(): optional<SensorReading>
    +readings(): vector<SensorReading>
  }

  class "GenericSensor" as C_GenericSensor
  class "LightSensor" as C_LightSensor
  class "MoistureSensor" as C_MoistureSensor

  class "GreenhouseController" as C_Controller {
    +registerDevice(device)
    +removeDevice(deviceId)
    +listDevices()
    +listDevicesByType(type)
    +findDevice(deviceId)
    +recordSensorReading(deviceId, value, timestamp)
    +latestReading(deviceId)
  }

  abstract class "HardwareSensor" as C_HardwareSensor {
    +read(outValue): bool
    +init(): bool
  }

  class "FixedValueSensor" as C_FixedValueSensor {
    -value_: double
  }

  abstract class "ApiClient" as C_ApiClient {
    +getDevices(): optional<string>
    +postSensorReading(remoteSensorId, reading): bool
  }

  class "RestApiClient" as C_RestApiClient {
    -baseUrl_: string
    -logger_: shared_ptr<Logger>
  }

  class "SensorRuntime" as C_Runtime {
    +bindSensor(localDeviceId, remoteSensorId, hardware): bool
    +pollOnce(localDeviceId): bool
    +pollAllOnce(): size_t
    +getAndBindNewRemoteSensors(): bool
  }

  enum "LogLevel" as C_LogLevel {
    Debug
    Info
    Warning
    Error
    Critical
  }

  class "Logger" as C_Logger {
    +debug(msg)
    +info(msg)
    +warning(msg)
    +error(msg)
    +critical(msg)
  }

  class "Utils namespace" as C_Utils <<utility>> {
    +jsonStringOrEmpty(object, key): string
  }
}

